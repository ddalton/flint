apiVersion: v1
kind: Config
clusters:
  - name: test-cluster
    cluster:
      # Kubernetes API server URL
      server: https://your-k8s-cluster:6443
      
      # Option 1: Certificate authority data (base64 encoded)
      certificate-authority-data: <base64-encoded-ca-cert>
      
      # Option 2: Path to CA certificate file (alternative to certificate-authority-data)
      # certificate-authority: /path/to/ca.crt
      
      # Option 3: Skip TLS verification (NOT recommended for production)
      # insecure-skip-tls-verify: true

contexts:
  - name: test-context
    context:
      cluster: test-cluster
      user: test-user
      # Optional: default namespace for operations
      namespace: default

# Set the default context
current-context: test-context

users:
  - name: test-user
    user:
      # Option 1: Certificate-based authentication
      client-certificate-data: <base64-encoded-client-cert>
      client-key-data: <base64-encoded-client-key>
      
      # Option 2: Certificate files (alternative to certificate-data)
      # client-certificate: /path/to/client.crt
      # client-key: /path/to/client.key
      
      # Option 3: Token-based authentication
      # token: <your-service-account-token>
      
      # Option 4: Username/password (if supported by cluster)
      # username: admin
      # password: your-password
      
      # Option 5: Exec plugin for dynamic authentication (e.g., AWS EKS, GKE)
      # exec:
      #   apiVersion: client.authentication.k8s.io/v1beta1
      #   command: aws
      #   args:
      #     - eks
      #     - get-token
      #     - --cluster-name
      #     - your-cluster-name
      #   env: null
      #   provideClusterInfo: false

# ============================================================================
# USAGE INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file to config/kubeconfig (without .example extension)
#    cp config/kubeconfig.example config/kubeconfig
#
# 2. Fill in the appropriate authentication details for your cluster
#
# 3. You can get your current kubeconfig settings from:
#    kubectl config view --flatten
#
# 4. To get base64 encoded certificates:
#    cat /path/to/cert.pem | base64 -w 0
#
# 5. For most users, the easiest option is to symlink your existing config:
#    ln -s ~/.kube/config config/kubeconfig
#
# 6. Test your configuration:
#    KUBECONFIG=config/kubeconfig kubectl cluster-info
#
# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# - NEVER commit config/kubeconfig to git (it's in .gitignore)
# - Use service accounts with minimal permissions for CI/CD
# - Consider using different kubeconfigs for dev vs production clusters
# - Rotate credentials regularly
# - For CI/CD, store kubeconfig as an encrypted secret
#
# ============================================================================
# EXAMPLES FOR COMMON PROVIDERS
# ============================================================================
#
# AWS EKS:
# Run: aws eks update-kubeconfig --name your-cluster-name
# This will update ~/.kube/config, then symlink it
#
# GKE (Google Kubernetes Engine):
# Run: gcloud container clusters get-credentials your-cluster-name
# This will update ~/.kube/config, then symlink it
#
# AKS (Azure Kubernetes Service):
# Run: az aks get-credentials --resource-group your-rg --name your-cluster
# This will update ~/.kube/config, then symlink it
#
# Minikube:
# Run: minikube update-context
# Then: ln -s ~/.kube/config config/kubeconfig
#
# Kind:
# Run: kind get kubeconfig --name your-cluster > config/kubeconfig
#
# ============================================================================
