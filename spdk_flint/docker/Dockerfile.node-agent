# Node Agent (DaemonSet)
# Manages local storage devices and SPDK setup on each node
ARG BASE_IMAGE=flint-base:latest
ARG CMAKE_BUILD_TYPE=Release
FROM ${BASE_IMAGE}

# Install tools needed for disk management and SPDK setup
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Disk management tools
    smartmontools \
    hdparm \
    sdparm \
    # Filesystem tools
    parted \
    gdisk \
    e2fsprogs \
    xfsprogs \
    # Block device tools
    util-linux \
    lsblk \
    blkid \
    # NVMe specific tools
    nvme-cli \
    # PCI tools for device discovery
    pciutils \
    # System tools
    dmidecode \
    lshw \
    # Network tools for NVMe-oF discovery
    iproute2 \
    # SPDK dependencies for setup
    kmod \
    udev \
    # Troubleshooting
    strace \
    ltrace \
    gdb \
    # System libraries needed for SPDK linking
    uuid-dev \
    libnuma-dev \
    # DPDK development libraries
    libdpdk-dev \
    # Intel Storage Acceleration Library (ISA-L) for CRC functions
    libisal-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy source code and build the business logic
COPY . /workspace/spdk_flint/
WORKDIR /workspace/spdk_flint

# Build the spdk_flint binary
RUN mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=${CMAKE_BUILD_TYPE} \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install

# Run tests
RUN cd build && ctest --output-on-failure || true

# Create backup directory with proper permissions
RUN mkdir -p /var/lib/spdk-csi/backups && \
    chown spdk-flint:spdk-flint /var/lib/spdk-csi/backups && \
    chmod 755 /var/lib/spdk-csi/backups

# Create device discovery script
RUN echo '#!/bin/bash\n\
# Discover available storage devices\n\
echo "=== Storage Device Discovery ==="\n\
echo "NVMe devices:"\n\
nvme list 2>/dev/null || echo "No NVMe devices found"\n\
echo ""\n\
echo "Block devices:"\n\
lsblk -d -o NAME,SIZE,TYPE,MODEL\n\
echo ""\n\
echo "PCI storage devices:"\n\
lspci | grep -i storage\n\
lspci | grep -i nvme\n\
echo ""\n\
' > /usr/local/bin/discover-devices.sh && chmod +x /usr/local/bin/discover-devices.sh

# Create SPDK setup validation script
RUN echo '#!/bin/bash\n\
# Validate SPDK setup on the node\n\
echo "=== SPDK Node Setup Validation ==="\n\
\n\
# Check if SPDK RPC socket exists\n\
if [ -S "${SPDK_RPC_URL#unix://}" ]; then\n\
    echo "✓ SPDK RPC socket found: ${SPDK_RPC_URL}"\n\
else\n\
    echo "✗ SPDK RPC socket not found: ${SPDK_RPC_URL}"\n\
fi\n\
\n\
# Check hugepages\n\
HUGEPAGES=$(cat /proc/meminfo | grep HugePages_Total | awk '"'"'{print $2}'"'"')\n\
if [ "$HUGEPAGES" -gt 0 ]; then\n\
    echo "✓ Hugepages configured: $HUGEPAGES"\n\
else\n\
    echo "⚠ No hugepages configured"\n\
fi\n\
\n\
# Check VFIO/UIO modules\n\
if lsmod | grep -q vfio_pci; then\n\
    echo "✓ VFIO-PCI module loaded"\n\
elif lsmod | grep -q uio_pci_generic; then\n\
    echo "✓ UIO-PCI-Generic module loaded"\n\
else\n\
    echo "⚠ No DPDK-compatible driver loaded"\n\
fi\n\
\n\
echo "=== Device Status ==="\n\
/usr/local/bin/discover-devices.sh\n\
' > /usr/local/bin/validate-setup.sh && chmod +x /usr/local/bin/validate-setup.sh

# Create health check script for node agent
RUN echo '#!/bin/bash\n\
# Health check for node agent\n\
PORT=${NODE_AGENT_PORT:-8090}\n\
\n\
# Check API endpoint\n\
if ! curl -f http://localhost:${PORT}/health >/dev/null 2>&1; then\n\
    echo "Node agent API not responding on port ${PORT}"\n\
    exit 1\n\
fi\n\
\n\
# Check if spdk_flint process is running\n\
if ! pgrep -x spdk_flint > /dev/null; then\n\
    echo "spdk_flint process not running"\n\
    exit 1\n\
fi\n\
\n\
echo "Node agent healthy"\n\
exit 0\n\
' > /usr/local/bin/node-agent-health.sh && chmod +x /usr/local/bin/node-agent-health.sh

# Create startup script with setup validation
RUN echo '#!/bin/bash\n\
echo "Starting SPDK Node Agent"\n\
echo "Node: ${NODE_ID:-$(hostname)}"\n\
echo "Discovery interval: ${DISCOVERY_INTERVAL:-300}s"\n\
echo "Backup path: ${BACKUP_PATH:-/var/lib/spdk-csi/backups}"\n\
echo ""\n\
\n\
# Run setup validation\n\
/usr/local/bin/validate-setup.sh\n\
echo ""\n\
\n\
echo "Node Agent API will be available at: http://localhost:${NODE_AGENT_PORT:-8090}"\n\
echo "API Endpoints:"\n\
echo "  GET  /health          - Health check"\n\
echo "  GET  /api/v1/disks    - List available disks"\n\
echo "  POST /api/v1/setup    - Setup disk with SPDK"\n\
echo ""\n\
\n\
exec "$@"\n\
' > /usr/local/bin/node-agent-start.sh && chmod +x /usr/local/bin/node-agent-start.sh

# Node Agent specific environment
ENV CSI_MODE=node-agent
ENV NODE_AGENT_PORT=8090
ENV LOG_LEVEL=info
ENV DISCOVERY_INTERVAL=300
ENV AUTO_INITIALIZE_BLOBSTORE=true
ENV BACKUP_PATH=/var/lib/spdk-csi/backups

# Expose node agent port
EXPOSE 8090

# Health check
HEALTHCHECK --interval=60s --timeout=15s --start-period=10s --retries=3 \
    CMD /usr/local/bin/node-agent-health.sh

# Node agent runs as privileged in DaemonSet, but set default user
USER spdk-flint

# Volume mount points for DaemonSet (host access needed)
VOLUME ["/dev", "/sys", "/proc", "/var/lib/spdk-csi"]

# Add labels for identification
LABEL service.type="node-agent"
LABEL service.port="8090"
LABEL service.requires="privileged"

ENTRYPOINT ["/usr/local/bin/node-agent-start.sh", "/usr/local/bin/spdk_flint"]
CMD ["--mode", "node-agent", "--log-level", "info"] 