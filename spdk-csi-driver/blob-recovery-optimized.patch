 static void
+bs_load_replay_batch_cpl(spdk_bs_sequence_t *seq, void *cb_arg, int bserrno)
+{
+	struct spdk_bs_load_ctx *ctx = cb_arg;
+	uint32_t i;
+
+	if (bserrno != 0) {
+		spdk_free(ctx->batch_pages);
+		bs_load_ctx_fail(ctx, bserrno);
+		return;
+	}
+
+	/* Process all pages in the batch */
+	for (i = 0; i < ctx->batch_count; i++) {
+		ctx->cur_page = ctx->batch_start + i;
+		ctx->page = &ctx->batch_pages[i];
+
+		if (bs_load_cur_md_page_valid(ctx) == true) {
+			if (ctx->page->sequence_num == 0 || ctx->in_page_chain == true) {
+				spdk_spin_lock(&ctx->bs->used_lock);
+				bs_claim_md_page(ctx->bs, ctx->cur_page);
+				spdk_spin_unlock(&ctx->bs->used_lock);
+				if (ctx->page->sequence_num == 0) {
+					spdk_bit_array_set(ctx->bs->used_blobids, ctx->cur_page);
+				}
+				if (bs_load_replay_md_parse_page(ctx, ctx->page)) {
+					spdk_free(ctx->batch_pages);
+					bs_load_ctx_fail(ctx, -EILSEQ);
+					return;
+				}
+			}
+		}
+	}
+
+	/* Move to next batch */
+	ctx->page_index = ctx->batch_start + ctx->batch_count - 1;
+	spdk_free(ctx->batch_pages);
+	bs_load_replay_batch_read(ctx);
+}
+
+static void
+bs_load_replay_batch_read(struct spdk_bs_load_ctx *ctx)
+{
+	spdk_bs_batch_t *batch;
+	uint32_t remaining, batch_size, i;
+	uint64_t lba;
+
+	remaining = ctx->super->md_len - ctx->page_index - 1;
+
+	if (remaining == 0) {
+		bs_load_replay_md_chain_cpl(ctx);
+		return;
+	}
+
+	batch_size = remaining < BS_RECOVERY_READ_BATCH ? remaining : BS_RECOVERY_READ_BATCH;
+	ctx->batch_start = ctx->page_index + 1;
+	ctx->batch_count = batch_size;
+
+	ctx->batch_pages = spdk_zmalloc(ctx->bs->md_page_size * batch_size, 0,
+	                                 NULL, SPDK_ENV_NUMA_ID_ANY, SPDK_MALLOC_DMA);
+	if (!ctx->batch_pages) {
+		SPDK_WARNLOG("Batch alloc failed, falling back to single-page mode\n");
+		ctx->cur_page = ctx->page_index + 1;
+		ctx->page = spdk_zmalloc(ctx->bs->md_page_size, 0,
+		                         NULL, SPDK_ENV_NUMA_ID_ANY, SPDK_MALLOC_DMA);
+		if (!ctx->page) {
+			bs_load_ctx_fail(ctx, -ENOMEM);
+			return;
+		}
+		bs_load_replay_cur_md_page(ctx);
+		return;
+	}
+
+	batch = bs_sequence_to_batch(ctx->seq, bs_load_replay_batch_cpl, ctx);
+	for (i = 0; i < batch_size; i++) {
+		lba = bs_md_page_to_lba(ctx->bs, ctx->batch_start + i);
+		bs_batch_read_dev(batch, &ctx->batch_pages[i], lba,
+		                  bs_byte_to_lba(ctx->bs, ctx->bs->md_page_size));
+	}
+	bs_batch_close(batch);
+}
