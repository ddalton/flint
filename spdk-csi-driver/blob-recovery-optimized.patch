-	if (!ctx->page) {
-		bs_load_ctx_fail(ctx, -ENOMEM);
-		return;
-	}
-	bs_load_replay_cur_md_page(ctx);
+	
+	SPDK_NOTICELOG("Recovery: Using batched reads (%u pages/batch)\n", 
+	               BS_RECOVERY_READ_BATCH);
+	
+	ctx->page_index = -1;
+	bs_load_replay_batch_read(ctx);
 }
 
