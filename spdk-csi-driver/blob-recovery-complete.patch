--- a/lib/blob/blobstore.c
+++ b/lib/blob/blobstore.c
@@ -4719,6 +4719,14 @@ bs_write_used_clusters_cpl(spdk_bs_sequence_t *seq, void *cb_arg, int bserrno)
 static void
 bs_load_write_used_clusters_cpl(spdk_bs_sequence_t *seq, void *cb_arg, int bserrno)
 {
+	struct spdk_bs_load_ctx *ctx = cb_arg;
+	
+	SPDK_NOTICELOG("==========================================\n");
+	SPDK_NOTICELOG("BLOBSTORE RECOVERY COMPLETE\n");
+	SPDK_NOTICELOG("  Status: %s\n", bserrno == 0 ? "SUCCESS" : "FAILED");
+	SPDK_NOTICELOG("  Free clusters: %lu / %lu\n", ctx->bs->num_free_clusters, ctx->bs->total_data_clusters);
+	SPDK_NOTICELOG("==========================================\n");
+
 	struct spdk_bs_load_ctx	*ctx = cb_arg;
 
 	spdk_free(ctx->mask);
@@ -4936,7 +4944,13 @@ static void
 bs_recover(struct spdk_bs_load_ctx *ctx)
 {
 	int		rc;
+	uint64_t total_size_gb = (ctx->bs->total_data_clusters * ctx->bs->cluster_sz) / (1024ULL * 1024 * 1024);
 
+	SPDK_NOTICELOG("==========================================\n");
+	SPDK_NOTICELOG("BLOBSTORE RECOVERY STARTING\n");
+	SPDK_NOTICELOG("  Disk size: %lu GB\n", total_size_gb);
+	SPDK_NOTICELOG("  MD pages to scan: %u (may take several minutes)\n", ctx->super->md_len);
+	SPDK_NOTICELOG("==========================================\n");
 	SPDK_NOTICELOG("Performing recovery on blobstore\n");
 	rc = spdk_bit_array_resize(&ctx->bs->used_md_pages, ctx->super->md_len);
 	if (rc < 0) {
@@ -5026,7 +5040,26 @@ bs_load_read_super_cpl(spdk_bs_sequence_t *seq, void *cb_arg, int bserrno)
 		return;
 	}
 
+	SPDK_NOTICELOG("==========================================\n");
+	SPDK_NOTICELOG("BLOBSTORE LOAD: Checking recovery status\n");
+	SPDK_NOTICELOG("  used_blobid_mask_len: %u\n", ctx->super->used_blobid_mask_len);
+	SPDK_NOTICELOG("  clean flag: %u\n", ctx->super->clean);
+	SPDK_NOTICELOG("  force_recover: %u\n", ctx->force_recover);
+	
 	if (ctx->super->used_blobid_mask_len == 0 || ctx->super->clean == 0 || ctx->force_recover) {
+		if (ctx->super->used_blobid_mask_len == 0) {
+			SPDK_NOTICELOG("  REASON: No blobid mask found\n");
+		}
+		if (ctx->super->clean == 0) {
+			SPDK_NOTICELOG("  REASON: Blobstore was not cleanly unmounted\n");
+		}
+		if (ctx->force_recover) {
+			SPDK_NOTICELOG("  REASON: Force recovery requested\n");
+		}
+		SPDK_NOTICELOG("  DECISION: Recovery required\n");
+		SPDK_NOTICELOG("==========================================\n");
 		bs_recover(ctx);
 	} else {
+		SPDK_NOTICELOG("  DECISION: Clean blobstore, no recovery needed\n");
+		SPDK_NOTICELOG("==========================================\n");
 		bs_load_read_used_pages(ctx);
 	}

