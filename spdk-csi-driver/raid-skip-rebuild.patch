+/*
+ * Leased raid bdev quiesce: the control plane quiesces guest io for a short
+ * window spanning several RPCs across nodes (final snapshot -> esnap clone ->
+ * skip_rebuild add). If the orchestrator dies mid-window an unleased quiesce
+ * would leave guest io hung until the initiator escalates to resets, so the
+ * quiesce auto-expires unless renewed: re-issuing bdev_raid_quiesce restarts
+ * the clock, bdev_raid_unquiesce releases it.
+ */
+struct raid_quiesce_lease {
+	char					*raid_name;
+	struct spdk_poller			*expiry_poller;
+	uint64_t				lease_us;
+	/* set while the initial quiesce RPC is in flight */
+	struct spdk_jsonrpc_request		*request;
+	/*
+	 * Number of in-flight skip_rebuild adds riding this lease. While pinned
+	 * the lease must not be released: channel installation runs under the
+	 * held quiesce, and releasing mid-install would resume writes onto
+	 * half-populated channels — the divergence the lease exists to prevent.
+	 * Expiry defers to the add's completion; unquiesce returns -EBUSY.
+	 */
+	uint32_t				pin_count;
+	/* the lease expired while pinned; release as soon as the pin drops */
+	bool					expired_while_pinned;
+	/*
+	 * An unquiesce (RPC or expiry) is in flight. The lease is freed only
+	 * after the unquiesce completes successfully — on failure the bdev is
+	 * still quiesced, so the lease (and its armed expiry poller) must
+	 * survive to retry the release.
+	 */
+	bool					releasing;
+	TAILQ_ENTRY(raid_quiesce_lease)		link;
+};
+
+static TAILQ_HEAD(, raid_quiesce_lease) g_raid_quiesce_leases =
+	TAILQ_HEAD_INITIALIZER(g_raid_quiesce_leases);
+
+static struct raid_quiesce_lease *
+raid_quiesce_lease_find(const char *raid_name)
+{
+	struct raid_quiesce_lease *lease;
+
+	TAILQ_FOREACH(lease, &g_raid_quiesce_leases, link) {
+		if (strcmp(lease->raid_name, raid_name) == 0) {
+			return lease;
+		}
+	}
+
+	return NULL;
+}
+
+static void
+raid_quiesce_lease_free(struct raid_quiesce_lease *lease)
+{
+	TAILQ_REMOVE(&g_raid_quiesce_leases, lease, link);
+	spdk_poller_unregister(&lease->expiry_poller);
+	free(lease->raid_name);
+	free(lease);
+}
+
+static void
+raid_quiesce_lease_release_done(void *ctx, int status)
+{
+	struct raid_quiesce_lease *lease = ctx;
+
+	if (status != 0) {
+		/* Still quiesced: keep the lease; the armed expiry poller retries. */
+		SPDK_ERRLOG("[lease %p] auto-unquiesce of '%s' failed: %s - will retry\n",
+			    (void *)lease, lease->raid_name, spdk_strerror(-status));
+		lease->releasing = false;
+		return;
+	}
+
+	SPDK_NOTICELOG("[lease %p] RELEASED '%s' after expiry (thread %s)\n",
+		       (void *)lease, lease->raid_name, spdk_thread_get_name(spdk_get_thread()));
+	raid_quiesce_lease_free(lease);
+}
+
+/*
+ * Attempt to unquiesce and free an expired lease. The lease is freed only on
+ * confirmed unquiesce (or when the raid bdev is gone, taking its quiesce state
+ * with it) — never while the bdev could still be quiesced, so a failure leaves
+ * the armed expiry poller to retry instead of stranding a quiesce with no
+ * lease tracking it.
+ */
+static void
+raid_quiesce_lease_try_release(struct raid_quiesce_lease *lease)
+{
+	struct raid_bdev *raid_bdev = raid_bdev_find_by_name(lease->raid_name);
+	int rc;
+
+	if (raid_bdev == NULL) {
+		raid_quiesce_lease_free(lease);
+		return;
+	}
+
+	lease->releasing = true;
+	rc = raid_bdev_unquiesce(raid_bdev, raid_quiesce_lease_release_done, lease);
+	if (rc != 0) {
+		SPDK_ERRLOG("[lease %p] failed to start auto-unquiesce of '%s': %s - will retry\n",
+			    (void *)lease, lease->raid_name, spdk_strerror(-rc));
+		lease->releasing = false;
+	}
+}
+
+static int
+raid_quiesce_lease_expired(void *ctx)
+{
+	struct raid_quiesce_lease *lease = ctx;
+
+	if (lease->releasing) {
+		/* a release attempt is already in flight */
+		return SPDK_POLLER_BUSY;
+	}
+
+	if (lease->pin_count > 0) {
+		/* A skip_rebuild add is installing channels under this quiesce;
+		 * defer — the add's completion releases the lease. */
+		SPDK_NOTICELOG("[lease %p] EXPIRED on '%s' with %u in-flight add(s) - deferring release\n",
+			       (void *)lease, lease->raid_name, lease->pin_count);
+		lease->expired_while_pinned = true;
+		return SPDK_POLLER_BUSY;
+	}
+
+	SPDK_NOTICELOG("[lease %p] EXPIRED on '%s' (thread %s) - auto-unquiescing\n",
+		       (void *)lease, lease->raid_name, spdk_thread_get_name(spdk_get_thread()));
+
+	raid_quiesce_lease_try_release(lease);
+
+	return SPDK_POLLER_BUSY;
+}
+
+static void
+raid_quiesce_lease_pin(struct raid_quiesce_lease *lease)
+{
+	lease->pin_count++;
+}
+
+static void
+raid_quiesce_lease_unpin(struct raid_quiesce_lease *lease)
+{
+	assert(lease->pin_count > 0);
+	lease->pin_count--;
+	if (lease->pin_count == 0 && lease->expired_while_pinned && !lease->releasing) {
+		/* the lease expired during the add; release immediately rather than
+		 * holding guest io gated until the poller's next period */
+		SPDK_NOTICELOG("[lease %p] deferred expiry on '%s' - releasing now\n",
+			       (void *)lease, lease->raid_name);
+		raid_quiesce_lease_try_release(lease);
+	}
+}
+
+static const struct spdk_json_object_decoder rpc_bdev_raid_quiesce_decoders[] = {
+	{"name", offsetof(struct rpc_bdev_raid_quiesce_ctx, name), spdk_json_decode_string},
+	{"lease_ms", offsetof(struct rpc_bdev_raid_quiesce_ctx, lease_ms), spdk_json_decode_uint64, true},
+};
+
+static void
+rpc_bdev_raid_quiesce_done(void *ctx, int status)
+{
+	struct raid_quiesce_lease *lease = ctx;
+	struct spdk_jsonrpc_request *request = lease->request;
+
+	lease->request = NULL;
+
+	if (status != 0) {
+		raid_quiesce_lease_free(lease);
+		spdk_jsonrpc_send_error_response_fmt(request, status, "Failed to quiesce raid bdev: %s",
+						     spdk_strerror(-status));
+		return;
+	}
+
+	SPDK_NOTICELOG("[lease %p] ARMED on '%s' for %" PRIu64 "ms (thread %s)\n",
+		       (void *)lease, lease->raid_name, lease->lease_us / 1000,
+		       spdk_thread_get_name(spdk_get_thread()));
+	lease->expiry_poller = SPDK_POLLER_REGISTER(raid_quiesce_lease_expired, lease, lease->lease_us);
+	if (lease->expiry_poller == NULL) {
+		/* never hold an unleased quiesce */
+		raid_quiesce_lease_try_release(lease);
+		spdk_jsonrpc_send_error_response(request, -ENOMEM,
+						 "Failed to register quiesce lease expiry poller");
+		return;
+	}
+
+	spdk_jsonrpc_send_bool_response(request, true);
+}
+
+static void
+rpc_bdev_raid_quiesce(struct spdk_jsonrpc_request *request,
+		      const struct spdk_json_val *params)
+{
+	struct rpc_bdev_raid_quiesce_ctx req = {};
+	struct raid_quiesce_lease *lease;
+	struct raid_bdev *raid_bdev;
+	int rc;
+
+	if (spdk_json_decode_object(params, rpc_bdev_raid_quiesce_decoders,
+				    SPDK_COUNTOF(rpc_bdev_raid_quiesce_decoders),
+				    &req)) {
+		spdk_jsonrpc_send_error_response(request, SPDK_JSONRPC_ERROR_PARSE_ERROR,
+						 "spdk_json_decode_object failed");
+		goto cleanup;
+	}
+
+	raid_bdev = raid_bdev_find_by_name(req.name);
+	if (raid_bdev == NULL) {
+		spdk_jsonrpc_send_error_response_fmt(request, -ENODEV, "raid bdev %s not found",
+						     req.name);
+		goto cleanup;
+	}
+
+	if (req.lease_ms == 0) {
+		req.lease_ms = 10000;
+	}
+
+	lease = raid_quiesce_lease_find(req.name);
+	if (lease != NULL) {
+		if (lease->request != NULL) {
+			spdk_jsonrpc_send_error_response_fmt(request, -EBUSY,
+							     "quiesce of raid bdev %s still in progress",
+							     req.name);
+			goto cleanup;
+		}
+		if (lease->releasing) {
+			/* an unquiesce is in flight and cannot be recalled */
+			spdk_jsonrpc_send_error_response_fmt(request, -EBUSY,
+							     "quiesce lease on raid bdev %s is being released",
+							     req.name);
+			goto cleanup;
+		}
+		/* renew: restart the expiry clock; the bdev stays quiesced. A
+		 * deferred expiry (expired while an add was in flight) is cancelled
+		 * by the renewal — the quiesce was never released. */
+		SPDK_NOTICELOG("[lease %p] RENEW on '%s' (thread %s)\n",
+			       (void *)lease, lease->raid_name, spdk_thread_get_name(spdk_get_thread()));
+		lease->expired_while_pinned = false;
+		spdk_poller_unregister(&lease->expiry_poller);
+		lease->lease_us = req.lease_ms * 1000;
+		lease->expiry_poller = SPDK_POLLER_REGISTER(raid_quiesce_lease_expired, lease,
+				       lease->lease_us);
+		if (lease->expiry_poller == NULL) {
+			SPDK_ERRLOG("[lease %p] failed to re-arm expiry poller on '%s'\n",
+				    (void *)lease, lease->raid_name);
+			if (lease->pin_count > 0) {
+				/* an add is riding the quiesce: must not release it now;
+				 * the add's completion (unpin) performs the release */
+				lease->expired_while_pinned = true;
+			} else {
+				raid_quiesce_lease_try_release(lease);
+			}
+			spdk_jsonrpc_send_error_response(request, -ENOMEM,
+							 "Failed to renew quiesce lease expiry poller");
+			goto cleanup;
+		}
+		spdk_jsonrpc_send_bool_response(request, true);
+		goto cleanup;
+	}
+
+	lease = calloc(1, sizeof(*lease));
+	if (lease == NULL) {
+		spdk_jsonrpc_send_error_response(request, -ENOMEM, spdk_strerror(ENOMEM));
+		goto cleanup;
+	}
+
+	lease->raid_name = strdup(req.name);
+	if (lease->raid_name == NULL) {
+		free(lease);
+		spdk_jsonrpc_send_error_response(request, -ENOMEM, spdk_strerror(ENOMEM));
+		goto cleanup;
+	}
+
+	lease->lease_us = req.lease_ms * 1000;
+	lease->request = request;
+	TAILQ_INSERT_TAIL(&g_raid_quiesce_leases, lease, link);
+
+	rc = raid_bdev_quiesce(raid_bdev, rpc_bdev_raid_quiesce_done, lease);
+	if (rc != 0) {
+		raid_quiesce_lease_free(lease);
+		spdk_jsonrpc_send_error_response_fmt(request, rc, "Failed to quiesce raid bdev: %s",
+						     spdk_strerror(-rc));
+	}
+
+cleanup:
+	free_rpc_bdev_raid_quiesce(&req);
+}
+SPDK_RPC_REGISTER("bdev_raid_quiesce", rpc_bdev_raid_quiesce, SPDK_RPC_RUNTIME)
+
+static const struct spdk_json_object_decoder rpc_bdev_raid_unquiesce_decoders[] = {
+	{"name", offsetof(struct rpc_bdev_raid_unquiesce_ctx, name), spdk_json_decode_string},
+};
+
+struct rpc_raid_unquiesce_ctx {
+	struct spdk_jsonrpc_request	*request;
+	struct raid_quiesce_lease	*lease;
+};
+
+static void
+rpc_bdev_raid_unquiesce_done(void *cb_arg, int status)
+{
+	struct rpc_raid_unquiesce_ctx *ctx = cb_arg;
+	struct spdk_jsonrpc_request *request = ctx->request;
+	struct raid_quiesce_lease *lease = ctx->lease;
+
+	free(ctx);
+
+	if (status != 0) {
+		/* Still quiesced: keep the lease so the armed expiry poller
+		 * retries the release — never strand a quiesce with no lease. */
+		SPDK_ERRLOG("[lease %p] release of '%s' failed: %s - expiry will retry\n",
+			    (void *)lease, lease->raid_name, spdk_strerror(-status));
+		lease->releasing = false;
+		spdk_jsonrpc_send_error_response_fmt(request, status,
+						     "Failed to unquiesce raid bdev: %s",
+						     spdk_strerror(-status));
+		return;
+	}
+
+	SPDK_NOTICELOG("[lease %p] RELEASED '%s' (thread %s)\n",
+		       (void *)lease, lease->raid_name, spdk_thread_get_name(spdk_get_thread()));
+	raid_quiesce_lease_free(lease);
+
