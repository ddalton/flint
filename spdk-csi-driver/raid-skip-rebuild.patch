--- a/module/bdev/raid/bdev_raid_rpc.c
+++ b/module/bdev/raid/bdev_raid_rpc.c
@@ -10,6 +10,7 @@
 #include "spdk/string.h"
 #include "spdk/log.h"
 #include "spdk/env.h"
+#include "spdk/thread.h"
 #include "spdk_internal/rpc_autogen.h"
 
 /*
