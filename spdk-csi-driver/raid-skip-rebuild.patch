 		  SPDK_RPC_STARTUP | SPDK_RPC_RUNTIME)
+
+/*
+ * Leased raid bdev quiesce: the control plane quiesces guest io for a short
+ * window spanning several RPCs across nodes (final snapshot -> esnap clone ->
+ * skip_rebuild add). If the orchestrator dies mid-window an unleased quiesce
+ * would leave guest io hung until the initiator escalates to resets, so the
+ * quiesce auto-expires unless renewed: re-issuing bdev_raid_quiesce restarts
+ * the clock, bdev_raid_unquiesce releases it.
+ */
+struct raid_quiesce_lease {
+	char					*raid_name;
+	struct spdk_poller			*expiry_poller;
+	uint64_t				lease_us;
+	/* set while the initial quiesce RPC is in flight */
+	struct spdk_jsonrpc_request		*request;
+	TAILQ_ENTRY(raid_quiesce_lease)		link;
+};
+
+static TAILQ_HEAD(, raid_quiesce_lease) g_raid_quiesce_leases =
+	TAILQ_HEAD_INITIALIZER(g_raid_quiesce_leases);
+
+static struct raid_quiesce_lease *
+raid_quiesce_lease_find(const char *raid_name)
+{
+	struct raid_quiesce_lease *lease;
+
+	TAILQ_FOREACH(lease, &g_raid_quiesce_leases, link) {
+		if (strcmp(lease->raid_name, raid_name) == 0) {
+			return lease;
+		}
+	}
+
+	return NULL;
+}
+
+static void
+raid_quiesce_lease_free(struct raid_quiesce_lease *lease)
+{
+	TAILQ_REMOVE(&g_raid_quiesce_leases, lease, link);
+	spdk_poller_unregister(&lease->expiry_poller);
+	free(lease->raid_name);
+	free(lease);
+}
+
+static void
+raid_quiesce_lease_expired_unquiesced(void *ctx, int status)
+{
+	if (status != 0) {
+		SPDK_ERRLOG("Auto-unquiesce after lease expiry failed: %s\n", spdk_strerror(-status));
+	}
+}
+
+static int
+raid_quiesce_lease_expired(void *ctx)
+{
+	struct raid_quiesce_lease *lease = ctx;
+	struct raid_bdev *raid_bdev = raid_bdev_find_by_name(lease->raid_name);
+	int rc;
+
+	SPDK_WARNLOG("Quiesce lease on raid bdev '%s' expired without renewal - auto-unquiescing\n",
+		     lease->raid_name);
+
+	if (raid_bdev != NULL) {
+		rc = raid_bdev_unquiesce(raid_bdev, raid_quiesce_lease_expired_unquiesced, NULL);
+		if (rc != 0) {
+			SPDK_ERRLOG("Failed to auto-unquiesce raid bdev '%s': %s\n",
+				    lease->raid_name, spdk_strerror(-rc));
+		}
+	}
+
+	raid_quiesce_lease_free(lease);
+
+	return SPDK_POLLER_BUSY;
+}
+
+static const struct spdk_json_object_decoder rpc_bdev_raid_quiesce_decoders[] = {
+	{"name", offsetof(struct rpc_bdev_raid_quiesce_ctx, name), spdk_json_decode_string},
+	{"lease_ms", offsetof(struct rpc_bdev_raid_quiesce_ctx, lease_ms), spdk_json_decode_uint64, true},
+};
+
+static void
+rpc_bdev_raid_quiesce_done(void *ctx, int status)
+{
+	struct raid_quiesce_lease *lease = ctx;
+	struct spdk_jsonrpc_request *request = lease->request;
+	struct raid_bdev *raid_bdev;
+
+	lease->request = NULL;
+
+	if (status != 0) {
+		raid_quiesce_lease_free(lease);
+		spdk_jsonrpc_send_error_response_fmt(request, status, "Failed to quiesce raid bdev: %s",
+						     spdk_strerror(-status));
+		return;
+	}
+
+	lease->expiry_poller = SPDK_POLLER_REGISTER(raid_quiesce_lease_expired, lease, lease->lease_us);
+	if (lease->expiry_poller == NULL) {
+		/* never hold an unleased quiesce */
+		raid_bdev = raid_bdev_find_by_name(lease->raid_name);
+		if (raid_bdev != NULL) {
+			raid_bdev_unquiesce(raid_bdev, NULL, NULL);
+		}
+		raid_quiesce_lease_free(lease);
+		spdk_jsonrpc_send_error_response(request, -ENOMEM,
+						 "Failed to register quiesce lease expiry poller");
+		return;
+	}
+
+	spdk_jsonrpc_send_bool_response(request, true);
+}
+
+static void
+rpc_bdev_raid_quiesce(struct spdk_jsonrpc_request *request,
+		      const struct spdk_json_val *params)
+{
+	struct rpc_bdev_raid_quiesce_ctx req = {};
+	struct raid_quiesce_lease *lease;
+	struct raid_bdev *raid_bdev;
+	int rc;
+
+	if (spdk_json_decode_object(params, rpc_bdev_raid_quiesce_decoders,
+				    SPDK_COUNTOF(rpc_bdev_raid_quiesce_decoders),
+				    &req)) {
+		spdk_jsonrpc_send_error_response(request, SPDK_JSONRPC_ERROR_PARSE_ERROR,
+						 "spdk_json_decode_object failed");
+		goto cleanup;
+	}
+
+	raid_bdev = raid_bdev_find_by_name(req.name);
+	if (raid_bdev == NULL) {
+		spdk_jsonrpc_send_error_response_fmt(request, -ENODEV, "raid bdev %s not found",
+						     req.name);
+		goto cleanup;
+	}
+
+	if (req.lease_ms == 0) {
+		req.lease_ms = 10000;
+	}
+
+	lease = raid_quiesce_lease_find(req.name);
+	if (lease != NULL) {
+		if (lease->request != NULL) {
+			spdk_jsonrpc_send_error_response_fmt(request, -EBUSY,
+							     "quiesce of raid bdev %s still in progress",
+							     req.name);
+			goto cleanup;
+		}
+		/* renew: restart the expiry clock; the bdev stays quiesced */
+		spdk_poller_unregister(&lease->expiry_poller);
+		lease->lease_us = req.lease_ms * 1000;
+		lease->expiry_poller = SPDK_POLLER_REGISTER(raid_quiesce_lease_expired, lease,
+				       lease->lease_us);
+		if (lease->expiry_poller == NULL) {
+			raid_bdev_unquiesce(raid_bdev, NULL, NULL);
+			raid_quiesce_lease_free(lease);
+			spdk_jsonrpc_send_error_response(request, -ENOMEM,
+							 "Failed to renew quiesce lease expiry poller");
+			goto cleanup;
+		}
+		spdk_jsonrpc_send_bool_response(request, true);
+		goto cleanup;
+	}
+
+	lease = calloc(1, sizeof(*lease));
+	if (lease == NULL) {
+		spdk_jsonrpc_send_error_response(request, -ENOMEM, spdk_strerror(ENOMEM));
+		goto cleanup;
+	}
+
+	lease->raid_name = strdup(req.name);
+	if (lease->raid_name == NULL) {
+		free(lease);
+		spdk_jsonrpc_send_error_response(request, -ENOMEM, spdk_strerror(ENOMEM));
+		goto cleanup;
+	}
+
+	lease->lease_us = req.lease_ms * 1000;
+	lease->request = request;
+	TAILQ_INSERT_TAIL(&g_raid_quiesce_leases, lease, link);
+
+	rc = raid_bdev_quiesce(raid_bdev, rpc_bdev_raid_quiesce_done, lease);
+	if (rc != 0) {
+		raid_quiesce_lease_free(lease);
+		spdk_jsonrpc_send_error_response_fmt(request, rc, "Failed to quiesce raid bdev: %s",
+						     spdk_strerror(-rc));
+	}
+
+cleanup:
+	free_rpc_bdev_raid_quiesce(&req);
+}
+SPDK_RPC_REGISTER("bdev_raid_quiesce", rpc_bdev_raid_quiesce, SPDK_RPC_RUNTIME)
+
+static const struct spdk_json_object_decoder rpc_bdev_raid_unquiesce_decoders[] = {
+	{"name", offsetof(struct rpc_bdev_raid_unquiesce_ctx, name), spdk_json_decode_string},
+};
+
+static void
+rpc_bdev_raid_unquiesce_done(void *ctx, int status)
+{
+	struct spdk_jsonrpc_request *request = ctx;
+
+	if (status != 0) {
+		spdk_jsonrpc_send_error_response_fmt(request, status,
+						     "Failed to unquiesce raid bdev: %s",
+						     spdk_strerror(-status));
+		return;
+	}
+
+	spdk_jsonrpc_send_bool_response(request, true);
+}
+
+static void
+rpc_bdev_raid_unquiesce(struct spdk_jsonrpc_request *request,
+			const struct spdk_json_val *params)
+{
+	struct rpc_bdev_raid_unquiesce_ctx req = {};
+	struct raid_quiesce_lease *lease;
+	struct raid_bdev *raid_bdev;
+	int rc;
+
+	if (spdk_json_decode_object(params, rpc_bdev_raid_unquiesce_decoders,
+				    SPDK_COUNTOF(rpc_bdev_raid_unquiesce_decoders),
+				    &req)) {
+		spdk_jsonrpc_send_error_response(request, SPDK_JSONRPC_ERROR_PARSE_ERROR,
+						 "spdk_json_decode_object failed");
+		goto cleanup;
+	}
+
+	lease = raid_quiesce_lease_find(req.name);
+	if (lease == NULL) {
+		spdk_jsonrpc_send_error_response_fmt(request, -ENOENT,
+						     "no quiesce lease held on raid bdev %s",
+						     req.name);
+		goto cleanup;
+	}
+
+	if (lease->request != NULL) {
+		spdk_jsonrpc_send_error_response_fmt(request, -EBUSY,
+						     "quiesce of raid bdev %s still in progress",
+						     req.name);
+		goto cleanup;
+	}
+
+	raid_quiesce_lease_free(lease);
+
+	raid_bdev = raid_bdev_find_by_name(req.name);
+	if (raid_bdev == NULL) {
+		spdk_jsonrpc_send_error_response_fmt(request, -ENODEV, "raid bdev %s not found",
+						     req.name);
+		goto cleanup;
+	}
+
+	rc = raid_bdev_unquiesce(raid_bdev, rpc_bdev_raid_unquiesce_done, request);
+	if (rc != 0) {
+		spdk_jsonrpc_send_error_response_fmt(request, rc, "Failed to unquiesce raid bdev: %s",
+						     spdk_strerror(-rc));
+	}
+
+cleanup:
+	free_rpc_bdev_raid_unquiesce(&req);
+}
+SPDK_RPC_REGISTER("bdev_raid_unquiesce", rpc_bdev_raid_unquiesce, SPDK_RPC_RUNTIME)
