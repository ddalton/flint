+/*
+ * skip_rebuild hot admission: attach an already-in-sync base bdev to an ONLINE
+ * raid bdev without a rebuild process. The caller MUST hold a raid quiesce
+ * (bdev_raid_quiesce) across the snapshot that produced this base AND this add
+ * — the RPC enforces it. Channel installation therefore happens with io
+ * already gated; no nested quiesce (a second overlapping module quiesce would
+ * pend behind the held one and deadlock the add). raid1 routes io purely off
+ * non-NULL base channels, so from the caller's unquiesce onward the new base
+ * serves reads and receives every write.
+ */
+static void
+raid_bdev_attach_insync_channel(struct spdk_io_channel_iter *i)
+{
+	struct raid_base_bdev_info *base_info = spdk_io_channel_iter_get_ctx(i);
+	struct spdk_io_channel *ch = spdk_io_channel_iter_get_channel(i);
+	struct raid_bdev_io_channel *raid_ch = spdk_io_channel_get_ctx(ch);
+	uint8_t slot = raid_bdev_base_bdev_slot(base_info);
+	int status = 0;
+
+	/* A channel created after is_configured was set already holds the slot. */
+	if (raid_ch->base_channel[slot] == NULL) {
+		raid_ch->base_channel[slot] = spdk_bdev_get_io_channel(base_info->desc);
+		if (raid_ch->base_channel[slot] == NULL) {
+			status = -ENOMEM;
+		}
+	}
+
+	spdk_for_each_channel_continue(i, status);
+}
+
+static void
+raid_bdev_attach_insync_channels_done(struct spdk_io_channel_iter *i, int status)
+{
+	struct raid_base_bdev_info *base_info = spdk_io_channel_iter_get_ctx(i);
+	struct raid_bdev *raid_bdev = base_info->raid_bdev;
+
+	if (status != 0) {
+		/*
+		 * Some channels may hold the new base, others not — remove the base
+		 * bdev so every channel converges back to an empty slot, then fail
+		 * the add (same unwind idiom as the rebuild-start failure path).
+		 */
+		SPDK_ERRLOG("Failed to attach in-sync base bdev %s to all channels of raid bdev %s: %s\n",
+			    base_info->name, raid_bdev->bdev.name, spdk_strerror(-status));
+		_raid_bdev_remove_base_bdev(base_info, NULL, NULL);
+		raid_bdev_configure_base_bdev_done(base_info, status);
+		return;
+	}
+
+	SPDK_NOTICELOG("Admitted in-sync base bdev %s to raid bdev %s (rebuild skipped)\n",
+		       base_info->name, raid_bdev->bdev.name);
+
+	if (raid_bdev->superblock_enabled) {
+		raid_bdev_process_finish_write_sb(raid_bdev);
+	}
+
+	raid_bdev_configure_base_bdev_done(base_info, 0);
+}
