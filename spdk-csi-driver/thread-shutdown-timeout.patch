--- a/lib/thread/thread.c
+++ b/lib/thread/thread.c
@@ -59,6 +59,9 @@ static spdk_new_thread_fn g_new_thread_fn = NULL;
 static spdk_thread_op_fn g_thread_op_fn = NULL;
 static spdk_thread_op_supported_fn g_thread_op_supported_fn = NULL;
 
+/* Configurable force shutdown timeout (0 = disabled) */
+static uint64_t g_force_shutdown_timeout_sec = 0;
+
 struct io_device {
 	void				*io_device;
 	char				*name;
@@ -134,6 +137,7 @@ struct spdk_thread {
 	uint64_t			exit_timeout_tsc;
 	/* Timestamp when an exiting thread was last polled */
 	uint64_t			last_exited_tsc;
+	uint64_t			exit_start_tsc;
 
 	TAILQ_HEAD(, spdk_poller)	active_pollers;
 	TAILQ_HEAD(, spdk_poller)	paused_pollers;
@@ -378,6 +382,17 @@ spdk_thread_lib_init_ext(const struct spdk_thread_lib_opts *opts, size_t ctx_sz
 		return -ENOMEM;
 	}
 
+	/* Read optional force shutdown timeout from environment */
+	const char *timeout_env = getenv("SPDK_FORCE_SHUTDOWN_TIMEOUT");
+	if (timeout_env) {
+		g_force_shutdown_timeout_sec = strtoul(timeout_env, NULL, 10);
+		if (g_force_shutdown_timeout_sec > 0) {
+			SPDK_WARNLOG("Force shutdown timeout enabled: will drain pending messages after %lu seconds\n",
+				     g_force_shutdown_timeout_sec);
+		}
+	}
+	SPDK_DEBUGLOG(thread, "Force shutdown timeout: %lu seconds (0 = disabled)\n", g_force_shutdown_timeout_sec);
+
 	SPDK_DEBUGLOG(thread, "spdk_msg_mempool was created with size: %zu\n",
 		      msg_mempool_sz);
 
@@ -682,7 +697,47 @@ thread_exit(struct spdk_thread *thread, uint64_t now)
 	}
 
 	if (spdk_ring_count(thread->messages) > 0) {
-		SPDK_INFOLOG(thread, "thread %s still has messages\n", thread->name);
+		uint32_t msg_count = spdk_ring_count(thread->messages);
+		
+		/* Check if force shutdown timeout is enabled and exceeded */
+		if (g_force_shutdown_timeout_sec > 0) {
+			if (thread->exit_start_tsc == 0) {
+				thread->exit_start_tsc = now;
+				SPDK_INFOLOG(thread, "thread %s has %u pending messages, starting shutdown timer (%lu sec timeout)\n",
+					     thread->name, msg_count, g_force_shutdown_timeout_sec);
+			}
+			
+			uint64_t elapsed_tsc = now - thread->exit_start_tsc;
+			uint64_t elapsed_sec = elapsed_tsc / spdk_get_ticks_hz();
+			uint64_t timeout_tsc = g_force_shutdown_timeout_sec * spdk_get_ticks_hz();
+			
+			if (elapsed_tsc >= timeout_tsc) {
+				SPDK_WARNLOG("thread %s forcing exit after %lu seconds with %u pending messages\n",
+					     thread->name, elapsed_sec, msg_count);
+				
+				/* Debug: Log first few message function pointers for diagnostics */
+				void *peek_msgs[10];
+				uint32_t peek_count = spdk_min(msg_count, 10);
+				uint32_t peeked = spdk_ring_dequeue(thread->messages, peek_msgs, peek_count);
+				
+				SPDK_WARNLOG("  Sample of %u/%u pending messages (fn pointers for debugging):\n", peeked, msg_count);
+				for (uint32_t i = 0; i < peeked; i++) {
+					struct spdk_msg *msg = peek_msgs[i];
+					SPDK_WARNLOG("    msg[%u]: fn=%p\n", i, msg ? msg->fn : NULL);
+				}
+				
+				/* Drain remaining messages (including peeked ones) */
+				uint32_t drained = peeked;
+				while (spdk_ring_count(thread->messages) > 0) {
+					void *msg;
+					spdk_ring_dequeue(thread->messages, &msg, 1);
+					spdk_mempool_put(g_spdk_msg_mempool, msg);
+					drained++;
+				}
+				SPDK_WARNLOG("thread %s drained %u messages, proceeding with exit\n", thread->name, drained);
+			} else {
+				SPDK_DEBUGLOG(thread, "thread %s has %u messages, waiting... (%lu/%lu sec)\n",
+					     thread->name, msg_count, elapsed_sec, g_force_shutdown_timeout_sec);
+			}
+		} else {
+			SPDK_INFOLOG(thread, "thread %s still has messages\n", thread->name);
+		}
 		return;
 	}

