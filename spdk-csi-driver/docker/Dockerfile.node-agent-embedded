#--------------------------------------------------------------------
# Stage 1: SPDK Builder 
# Build SPDK from source with development libraries
#--------------------------------------------------------------------
FROM ubuntu:24.04 AS spdk-builder

# Install SPDK build dependencies including ISA-L autotools
RUN apt-get update && apt-get install -y \
    build-essential \
    pkg-config \
    libaio-dev \
    libssl-dev \
    libnuma-dev \
    libpciaccess-dev \
    libcunit1-dev \
    libncurses5-dev \
    liburing-dev \
    libfuse3-dev \
    python3 \
    python3-pyelftools \
    git \
    wget \
    meson \
    nasm \
    autoconf \
    automake \
    libtool \
    uuid-dev \
    yasm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /spdk

# Clone, configure, and build SPDK with proper ISA-L integration for shared libraries
RUN git clone https://github.com/spdk/spdk.git . && \
    git checkout v25.05 && \
    git submodule update --init --recursive && \
    echo "=== Building ISA-L first ===" && \
    cd isa-l && \
    ./autogen.sh && \
    ./configure --enable-shared --enable-static --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd .. && \
    echo "=== Configuring SPDK for static linking (avoids ISA-L shared lib issues) ===" && \
    PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:$PKG_CONFIG_PATH ./configure --with-ublk --enable-debug --without-shared && \
    make -j$(nproc)

#--------------------------------------------------------------------
# Stage 2: Rust Builder with SPDK integration
# Build the node-agent with SPDK embedded
#--------------------------------------------------------------------
FROM docker-private.infra.cloudera.com/cloudera_base/hardened/cloudera-rust:1.85 AS rust-builder

# Switch to root to install build dependencies
USER root

# Install build dependencies for embedded SPDK
# Try to install clang/llvm, fallback gracefully if not available in Chainguard
RUN apk add --no-cache \
    perl \
    linux-headers \
    openssl-dev \
    pkgconf \
    clang \
    protoc \
    protobuf-dev \
    liburing-dev \
    util-linux-dev \
    numactl-dev \
    && (apk add --no-cache llvm-dev || echo "llvm-dev not available in Chainguard") \
    && rm -rf /var/cache/apk/*

# Copy SPDK static libraries and headers from spdk-builder stage
COPY --from=spdk-builder /spdk/build/lib/ /usr/local/lib/
COPY --from=spdk-builder /spdk/include/spdk/ /usr/local/include/spdk/
COPY --from=spdk-builder /spdk/build/include/ /usr/local/include/
# Copy DPDK static libraries (built as part of SPDK --disable-shared)
COPY --from=spdk-builder /spdk/dpdk/build/lib/ /usr/local/lib/

# Copy ISA-L static libraries explicitly (CRC functions are needed for v25.05)
COPY --from=spdk-builder /usr/local/lib/libisal.a /usr/local/lib/ || echo "ISA-L static lib not found"
COPY --from=spdk-builder /usr/local/lib/libisal.so* /usr/local/lib/ || echo "ISA-L shared lib not found" 
COPY --from=spdk-builder /usr/local/lib/libisa-l.* /usr/local/lib/ || echo "Alternative ISA-L lib not found"
COPY --from=spdk-builder /usr/local/lib/libisal_crypto.* /usr/local/lib/ || echo "ISA-L crypto lib not found"

# Copy any ISA-L object files that might contain CRC functions in v25.05
COPY --from=spdk-builder /spdk/isa-l/.libs/ /usr/local/lib/isal-objects/ || echo "ISA-L object files not found"

# Ensure static libraries are available for linking and debug library structure
RUN echo "=== SPDK v25.05 Library Structure Debug ===" && \
    echo "SPDK static libraries:" && \
    find /usr/local/lib -name "libspdk*.a" | head -10 && \
    echo "DPDK static libraries:" && \
    find /usr/local/lib -name "librte*.a" | head -10 && \
    echo "ISA-L libraries:" && \
    find /usr/local/lib -name "*isal*" && \
    echo "Total static libraries: $(find /usr/local/lib -name '*.a' | wc -l)" && \
    echo "========================================"

# Create pkg-config files for SPDK libraries if they don't exist
RUN mkdir -p /usr/local/lib/pkgconfig

# Set up environment for SPDK static linking
ENV PKG_CONFIG_PATH=/usr/local/lib/pkgconfig
ENV SPDK_ROOT_DIR=/usr/local

# Set OpenSSL environment variables to help openssl-sys find libraries
ENV OPENSSL_DIR=/usr
ENV OPENSSL_LIB_DIR=/usr/lib
ENV OPENSSL_INCLUDE_DIR=/usr/include
ENV PKG_CONFIG_ALLOW_SYSTEM_CFLAGS=1

# Switch back to unprivileged user for build
USER 65532

WORKDIR /app

# Force cache invalidation for Rust build with current timestamp
RUN echo "Build timestamp: $(date)" > /tmp/build_timestamp

# Copy Rust source files
COPY --chown=65532:65532 Cargo.toml Cargo.lock ./
COPY --chown=65532:65532 src/ ./src/
COPY --chown=65532:65532 build.rs ./
COPY --chown=65532:65532 proto/ ./proto/
COPY --chown=65532:65532 wrapper.h ./

# Debug: List available SPDK libraries and check ISA-L symbols before build
RUN echo "=== SPDK Library Debug Info ===" && \
    echo "Contents of /usr/local/lib:" && \
    ls -la /usr/local/lib/ | grep -E '\.(a|so)' | wc -l && echo " libraries found" && \
    echo "SPDK libraries:" && \
    ls -la /usr/local/lib/libspdk* | head -10 || echo "No SPDK libraries found" && \
    echo "DPDK libraries:" && \
    ls -la /usr/local/lib/librte* | head -5 || echo "No DPDK libraries found" && \
    echo "ISA-L libraries:" && \
    ls -la /usr/local/lib/*isal* || echo "No ISA-L libraries found" && \
    echo "Verifying static libraries contain ISA-L symbols:" && \
    nm /usr/local/lib/libspdk_accel.a | grep -E '(isal_|crc32_iscsi|xor_gen)' | head -5 || echo "ISA-L symbols not found in SPDK accel static library - checking other libs" && \
    echo "Static libraries available:" && \
    ls -la /usr/local/lib/*.a | head -10 || echo "No static libraries found" && \
    echo "Environment:" && \
    echo "PKG_CONFIG_PATH=$PKG_CONFIG_PATH" && \
    echo "LD_LIBRARY_PATH=$LD_LIBRARY_PATH" && \
    echo "================================"

# Build the node-agent with embedded SPDK
# Note: This will require updating Cargo.toml with SPDK bindings
RUN cargo build --release --bin node-agent

#--------------------------------------------------------------------
# Stage 3: Runtime Image
# Combined node-agent + SPDK runtime environment
#--------------------------------------------------------------------
FROM ubuntu:24.04

# Install combined runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Node-agent dependencies
    pciutils \
    util-linux \
    curl \
    ca-certificates \
    # SPDK runtime dependencies  
    libaio1t64 \
    libnuma1 \
    libssl3 \
    libpciaccess0 \
    libcunit1 \
    liburing2 \
    libfuse3-3 \
    libuuid1 \
    python3 \
    kmod \
    grep \
    openssl \
    && rm -rf /var/lib/apt/lists/*

# Copy SPDK management scripts and Python modules (static binary doesn't need runtime libs)
COPY --from=spdk-builder /spdk/scripts/ /usr/local/scripts/
COPY --from=spdk-builder /spdk/python/ /usr/local/lib/python3.12/dist-packages/

# Copy the embedded node-agent binary
COPY --from=rust-builder /app/target/release/node-agent /usr/local/bin/

# Create runtime directories
RUN mkdir -p /var/tmp /etc/spdk /usr/lib/ssl && \
    if [ ! -f /usr/lib/ssl/openssl.cnf ] && [ -f /etc/ssl/openssl.cnf ]; then \
        ln -sf /etc/ssl/openssl.cnf /usr/lib/ssl/openssl.cnf; \
    fi && \
    chmod +x /usr/local/scripts/*.sh

# Static linking - no runtime library path needed

ENTRYPOINT ["/usr/local/bin/node-agent"] 