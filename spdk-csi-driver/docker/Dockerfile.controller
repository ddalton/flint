FROM docker-private.infra.cloudera.com/cloudera_base/hardened/cloudera-rust:1.85 AS builder

# --- System-level setup ---
# Switch to root to install build dependencies.
# - perl: Required by the openssl-sys crate.
# - protobuf-dev: Provides standard Google .proto files (e.g., timestamp.proto).
# - openssl-dev: Required by the openssl-sys crate for SSL/TLS functionality.
# - pkgconf: Required to locate OpenSSL libraries (Alpine's pkg-config).
USER root
RUN apk add --no-cache perl protobuf-dev openssl-dev pkgconf || \
    apk add --no-cache perl protobuf-dev openssl-dev

# Set OpenSSL environment variables to help openssl-sys find libraries
ENV OPENSSL_DIR=/usr
ENV OPENSSL_LIB_DIR=/usr/lib
ENV OPENSSL_INCLUDE_DIR=/usr/include
ENV PKG_CONFIG_ALLOW_SYSTEM_CFLAGS=1

# Skip SPDK native bindings for controller (only needs HTTP RPC)
ENV SKIP_SPDK_BINDINGS=true

# Switch back to the unprivileged user for the actual build process.
USER 65532

# --- Application build ---
WORKDIR /app

# COPY all necessary source files with the correct ownership.
COPY --chown=65532:65532 Cargo.toml Cargo.lock ./
COPY --chown=65532:65532 src/ ./src/
COPY --chown=65532:65532 build.rs ./
COPY --chown=65532:65532 proto/ ./proto/

# The build will now have all necessary system dependencies.
RUN cargo build --release --bin controller

# --- Final Stage ---
FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/controller /usr/local/bin/

ENTRYPOINT ["/usr/local/bin/controller"]
